SIGNTOOL_PATH=C:\Program Files (x86)\Windows Kits\10\bin\10.0.22621.0\x64\signtool.exe
WINDOWS_SIGN_CERT_FILE=certs\RelyyConvert-dev-codesign.pfx
WINDOWS_CERT_PASSWORD=change-me
WINDOWS_SIGN_CERT_SHA1=
WINDOWS_SIGN_DIGEST=SHA256

# macOS signing/notarization
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_SIGN_IDENTITY=Developer ID Application: Your Name (TEAMID)
APPLE_INSTALLER_SIGN_IDENTITY=Developer ID Installer: Your Name (TEAMID)
APPLE_KEYCHAIN_PROFILE=relyy-notary
# Or use App Store Connect API key notarization:
APPLE_API_KEY_PATH=/absolute/path/AuthKey_XXXXXX.p8
APPLE_API_KEY_ID=XXXXXX
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
